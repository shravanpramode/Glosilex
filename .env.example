# ─── Glosilex Environment Variables ────────────────────────────────────────────
#
# HOW THIS WORKS:
# - .env.example is documentation only — never put real keys here
# - For AI Studio: add VITE_GEMINI_API_KEY in the Secrets panel
# - For Vercel: add all VITE_ variables in Project Settings → Environment Variables
# - SUPABASE_URL and SUPABASE_ANON_KEY are entered by the user at runtime
#   via the Credentials modal — they do NOT need to be set as build-time env vars
# - SUPABASE_SERVICE_ROLE_KEY is only for running ingest.js locally — never on Vercel
# ────────────────────────────────────────────────────────────────────────────────

# Required — Gemini AI API key
# Set as VITE_GEMINI_API_KEY in AI Studio Secrets or Vercel Environment Variables
VITE_GEMINI_API_KEY="your-gemini-api-key-here"

# AI Studio injects this automatically at runtime
APP_URL="MY_APP_URL"

# ─── For local development only (.env.local, never commit real values) ──────────
# VITE_SUPABASE_URL="https://your-project.supabase.co"
# VITE_SUPABASE_ANON_KEY="eyJh..."

# ─── For ingest.js only — never set in Vercel, never commit real value ──────────
# SUPABASE_SERVICE_ROLE_KEY="eyJh..."
# GEMINI_API_KEY="your-gemini-api-key-here"