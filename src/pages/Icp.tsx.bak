import React, { useState, useRef } from 'react';
import { FileCheck, Upload, FileText, ArrowRight, Download, ChevronDown, ChevronUp } from 'lucide-react';
import { extractTextFromPdf } from '../utils/pdfParser';
import { getGemini } from '../services/gemini';
import { retrieveChunks, formatRetrievedContext } from '../services/retrieval';
import { LoadingSteps } from '../components/LoadingSteps';

export const Icp: React.FC = () => {
  const [file, setFile] = useState<File | null>(null);
  const [hasIcp, setHasIcp] = useState(true);
  const [scometChecked, setScometChecked] = useState(true);
  const [earChecked, setEarChecked] = useState(true);
  
  const [isLoading, setIsLoading] = useState(false);
  const [loadingSteps, setLoadingSteps] = useState<string[]>([]);
  const [currentStep, setCurrentStep] = useState(0);
  const [result, setResult] = useState<any>(null);
  const [expandedRow, setExpandedRow] = useState<number | null>(null);

  const fileInputRef = useRef<HTMLInputElement>(null);

  const handleFileUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const selected = e.target.files?.[0];
    if (selected && selected.type === 'application/pdf') {
      setFile(selected);
      setHasIcp(true);
    } else {
      alert('Please upload a PDF document.');
    }
  };

  const runAnalysis = async () => {
    if (hasIcp && !file) {
      alert('Please upload an ICP document or select "No ICP".');
      return;
    }
    
    setIsLoading(true);
    setResult(null);

    try {
      const steps = [
        hasIcp ? '📄 Extracting ICP structure...' : '📄 Initializing blank ICP template...',
        scometChecked ? '🇮🇳 Retrieving SCOMET ICP requirements...' : '⏭️ Skipping SCOMET...',
        earChecked ? '🇺🇸 Retrieving EAR ICP requirements...' : '⏭️ Skipping EAR...',
        '🔍 Identifying gaps...',
        '✍️ Generating SOP language...',
        '📊 Building documentation flow...'
      ];
      setLoadingSteps(steps);
      setCurrentStep(0);

      let icpText = '';
      let dynamicQuery = 'ICP requirements internal compliance program elements record keeping training screening';
      
      if (hasIcp && file) {
        icpText = await extractTextFromPdf(file);
        dynamicQuery = icpText.substring(0, 500);
      }
      
      setCurrentStep(1);
      let scometChunks: any[] = [];
      if (scometChecked) {
        scometChunks = await retrieveChunks(dynamicQuery, ['SCOMET_INDIA'], 5);
      }
      
      setCurrentStep(2);
      let earChunks: any[] = [];
      if (earChecked) {
        earChunks = await retrieveChunks(dynamicQuery, ['EAR_US'], 5);
      }

      setCurrentStep(3);
      const context = formatRetrievedContext([...scometChunks, ...earChunks]);
      
      setCurrentStep(4);
      const prompt = `
You are SemiShield, an AI-powered semiconductor trade compliance copilot.
Perform an Internal Compliance Program (ICP) Gap Analysis based ONLY on the retrieved regulatory chunks.

USER ICP TEXT (if any):
${icpText ? icpText.substring(0, 3000) : 'NO ICP PROVIDED. Assume all requirements are missing.'}

RETRIEVED REGULATORY CONTEXT:
${context}

Provide a JSON response with the following structure:
{
  "summary": {
    "met": number,
    "gaps": number,
    "partial": number,
    "scometCompliance": number,
    "earCompliance": number
  },
  "gaps": [
    {
      "component": string,
      "status": "COMPLIANT" | "PARTIAL" | "MISSING",
      "jurisdiction": "SCOMET" | "EAR" | "Both",
      "priority": "CRITICAL" | "HIGH" | "MEDIUM" | "LOW",
      "description": string,
      "sopText": string,
      "citation": string
    }
  ]
}
Return ONLY valid JSON.
`;

      const ai = getGemini();
      const chat = ai.chats.create({
        model: 'gemini-3.1-pro-preview',
        config: { temperature: 0.2 }
      });

      const response = await chat.sendMessage({ message: prompt });
      const jsonStr = response.text?.replace(/```json/g, '').replace(/```/g, '').trim() || '{}';
      const parsedResult = JSON.parse(jsonStr);
      
      setCurrentStep(5);
      // Simulate flow building
      await new Promise(r => setTimeout(r, 500));
      
      setResult(parsedResult);

    } catch (error) {
      console.error('ICP Analysis error:', error);
      alert('Analysis failed. Please try again.');
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="flex flex-col min-h-[calc(100vh-64px)] bg-slate-50 p-4 sm:p-6 lg:p-8">
      <div className="max-w-6xl mx-auto w-full space-y-8">
        
        {/* Header */}
        <div className="flex items-center gap-3 mb-8">
          <div className="bg-blue-100 p-3 rounded-xl">
            <FileCheck className="h-8 w-8 text-blue-600" />
          </div>
          <div>
            <h1 className="text-2xl font-bold text-slate-900">ICP Gap Analyzer</h1>
            <p className="text-slate-500">Review your Internal Compliance Program against SCOMET and EAR requirements.</p>
          </div>
        </div>

        {/* Input Section */}
        {!result && !isLoading && (
          <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
            <div className="grid md:grid-cols-2 gap-8">
              <div>
                <h3 className="text-lg font-bold text-slate-800 mb-4">1. Upload Document</h3>
                
                <div className="space-y-4">
                  <label className="flex items-center gap-3 p-4 border rounded-xl cursor-pointer hover:bg-slate-50 transition-colors">
                    <input 
                      type="radio" 
                      name="icpMode" 
                      checked={hasIcp} 
                      onChange={() => setHasIcp(true)}
                      className="w-5 h-5 text-blue-600"
                    />
                    <span className="font-medium text-slate-800">I have an existing ICP</span>
                  </label>
                  
                  {hasIcp && (
                    <div 
                      className={`ml-8 border-2 border-dashed rounded-xl p-6 text-center cursor-pointer transition-colors ${
                        file ? 'border-blue-500 bg-blue-50' : 'border-slate-300 hover:border-blue-400'
                      }`}
                      onClick={() => fileInputRef.current?.click()}
                    >
                      <input 
                        type="file" 
                        accept=".pdf" 
                        className="hidden" 
                        ref={fileInputRef}
                        onChange={handleFileUpload}
                      />
                      {file ? (
                        <div className="flex flex-col items-center">
                          <FileText className="h-8 w-8 text-blue-600 mb-2" />
                          <span className="font-medium text-blue-900 text-sm">{file.name}</span>
                        </div>
                      ) : (
                        <div className="flex flex-col items-center">
                          <Upload className="h-8 w-8 text-slate-400 mb-2" />
                          <span className="font-medium text-slate-700 text-sm">Upload PDF</span>
                        </div>
                      )}
                    </div>
                  )}

                  <label className="flex items-center gap-3 p-4 border rounded-xl cursor-pointer hover:bg-slate-50 transition-colors">
                    <input 
                      type="radio" 
                      name="icpMode" 
                      checked={!hasIcp} 
                      onChange={() => { setHasIcp(false); setFile(null); }}
                      className="w-5 h-5 text-blue-600"
                    />
                    <span className="font-medium text-slate-800">I don't have an ICP yet (Start from scratch)</span>
                  </label>
                </div>
              </div>

              <div>
                <h3 className="text-lg font-bold text-slate-800 mb-4">2. Select Scope</h3>
                <div className="space-y-3">
                  <label className="flex items-center gap-3 p-4 border rounded-xl cursor-pointer hover:bg-slate-50 transition-colors">
                    <input 
                      type="checkbox" 
                      checked={scometChecked} 
                      onChange={(e) => setScometChecked(e.target.checked)}
                      className="w-5 h-5 text-blue-600 rounded"
                    />
                    <span className="font-medium text-slate-800">🇮🇳 India SCOMET (Category 7)</span>
                  </label>
                  <label className="flex items-center gap-3 p-4 border rounded-xl cursor-pointer hover:bg-slate-50 transition-colors">
                    <input 
                      type="checkbox" 
                      checked={earChecked} 
                      onChange={(e) => setEarChecked(e.target.checked)}
                      className="w-5 h-5 text-blue-600 rounded"
                    />
                    <span className="font-medium text-slate-800">🇺🇸 US EAR / BIS</span>
                  </label>
                </div>

                <div className="mt-8">
                  <button
                    onClick={runAnalysis}
                    disabled={(!hasIcp && !scometChecked && !earChecked) || (hasIcp && !file)}
                    className="w-full bg-blue-600 text-white font-bold py-4 px-6 rounded-xl hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed transition-colors flex items-center justify-center gap-2 text-lg"
                  >
                    Run Gap Analysis <ArrowRight className="h-5 w-5" />
                  </button>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* Loading State */}
        {isLoading && (
          <div className="flex justify-center py-12">
            <LoadingSteps steps={loadingSteps} currentStepIndex={currentStep} />
          </div>
        )}

        {/* Results */}
        {result && !isLoading && (
          <div className="space-y-6">
            {/* Summary Bar */}
            <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col md:flex-row items-center justify-between gap-6">
              <div>
                <h2 className="text-2xl font-bold text-slate-900">
                  {result.summary.met} of {result.summary.met + result.summary.gaps + result.summary.partial} requirements met
                </h2>
                <p className="text-slate-500 font-medium mt-1">
                  <span className="text-red-500">{result.summary.gaps} gaps identified</span> | <span className="text-amber-500">{result.summary.partial} partial</span>
                </p>
              </div>
              <div className="flex gap-8">
                <div className="text-center">
                  <div className="text-3xl font-bold text-blue-600">{result.summary.scometCompliance}%</div>
                  <div className="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">SCOMET Compliance</div>
                </div>
                <div className="text-center">
                  <div className="text-3xl font-bold text-blue-600">{result.summary.earCompliance}%</div>
                  <div className="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">EAR Compliance</div>
                </div>
              </div>
            </div>

            {/* Gap Table */}
            <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
              <div className="px-6 py-4 border-b border-slate-200 bg-slate-50">
                <h3 className="font-bold text-slate-800">Detailed Gap Analysis</h3>
              </div>
              <div className="divide-y divide-slate-200">
                {result.gaps.map((gap: any, idx: number) => (
                  <div key={idx} className="bg-white">
                    <div 
                      className={`px-6 py-4 flex items-center justify-between cursor-pointer hover:bg-slate-50 transition-colors ${
                        expandedRow === idx ? 'bg-slate-50' : ''
                      }`}
                      onClick={() => setExpandedRow(expandedRow === idx ? null : idx)}
                    >
                      <div className="flex items-center gap-4 flex-1">
                        <div className="w-8 flex justify-center">
                          {gap.status === 'COMPLIANT' ? <span className="text-green-500 text-xl">✅</span> :
                           gap.status === 'PARTIAL' ? <span className="text-amber-500 text-xl">⚠️</span> :
                           <span className="text-red-500 text-xl">❌</span>}
                        </div>
                        <div className="flex-1">
                          <h4 className="font-bold text-slate-900">{gap.component}</h4>
                          <p className="text-sm text-slate-600 mt-1">{gap.description}</p>
                        </div>
                        <div className="hidden md:flex items-center gap-4 w-64 justify-end">
                          <span className="text-xs font-medium text-slate-500 bg-slate-100 px-2 py-1 rounded border border-slate-200">
                            {gap.jurisdiction}
                          </span>
                          <span className={`text-xs font-bold px-2 py-1 rounded ${
                            gap.priority === 'CRITICAL' ? 'bg-red-100 text-red-800' :
                            gap.priority === 'HIGH' ? 'bg-orange-100 text-orange-800' :
                            'bg-slate-100 text-slate-800'
                          }`}>
                            {gap.priority}
                          </span>
                        </div>
                      </div>
                      <div className="ml-4 text-slate-400">
                        {expandedRow === idx ? <ChevronUp /> : <ChevronDown />}
                      </div>
                    </div>
                    
                    {/* Expanded Content */}
                    {expandedRow === idx && (gap.status === 'MISSING' || gap.status === 'PARTIAL') && (
                      <div className="px-6 py-6 bg-slate-50 border-t border-slate-200 pl-18">
                        <h5 className="text-sm font-bold text-slate-800 mb-2">Generated SOP Text (Ready to use)</h5>
                        <div className="bg-slate-900 rounded-lg p-4 relative group">
                          <pre className="text-sm text-green-400 font-mono whitespace-pre-wrap font-medium leading-relaxed">
                            {gap.sopText}
                          </pre>
                          <button 
                            className="absolute top-2 right-2 bg-slate-700 hover:bg-slate-600 text-white text-xs py-1 px-3 rounded transition-colors opacity-0 group-hover:opacity-100"
                            onClick={(e) => {
                              e.stopPropagation();
                              navigator.clipboard.writeText(gap.sopText);
                              alert('Copied to clipboard!');
                            }}
                          >
                            Copy Text
                          </button>
                        </div>
                        <div className="mt-3 text-sm text-slate-500 flex items-start gap-2">
                          <span className="font-semibold text-slate-700">Citation:</span> {gap.citation}
                        </div>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>

            {/* Documentation Flow Diagram */}
            <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
              <div className="px-6 py-4 border-b border-slate-200 bg-slate-50">
                <h3 className="font-bold text-slate-800">Recommended Documentation Flow</h3>
              </div>
              <div className="p-8 overflow-x-auto">
                <div className="flex items-center space-x-4 min-w-max">
                  <div className="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-2 rounded-lg font-medium text-sm">Product Identified</div>
                  <ArrowRight className="text-slate-400 h-5 w-5" />
                  <div className="bg-orange-50 border border-orange-200 text-orange-800 px-4 py-2 rounded-lg font-medium text-sm">SCOMET Cat 7 Check</div>
                  <ArrowRight className="text-slate-400 h-5 w-5" />
                  <div className="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-2 rounded-lg font-medium text-sm">EAR CCL Check</div>
                  <ArrowRight className="text-slate-400 h-5 w-5" />
                  <div className="bg-slate-50 border border-slate-300 text-slate-800 px-4 py-2 rounded-lg font-medium text-sm">Entity Screening</div>
                  <ArrowRight className="text-slate-400 h-5 w-5" />
                  <div className="bg-purple-50 border border-purple-200 text-purple-800 px-4 py-2 rounded-lg font-medium text-sm">License Required?</div>
                </div>
              </div>
            </div>

            <div className="flex justify-end pt-4">
              <button className="bg-white border border-slate-300 text-slate-700 font-medium py-2 px-6 rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-2">
                <Download className="h-4 w-4" /> Download Full ICP Gap Report PDF
              </button>
            </div>

          </div>
        )}
      </div>
    </div>
  );
};
